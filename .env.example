# ID da Planilha Google (Planilha pública ou compartilhada)
GOOGLE_SHEET_ID=
# Chave da API do OpenRouter e Modelo (opção 2)
# Exemplo de modelo gratuito:
# Outro modelo: mistralai/mistral-7b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-thinking:free

# Configurações do servidor backend FastAPI
HOST=127.0.0.1
PORT=8000
